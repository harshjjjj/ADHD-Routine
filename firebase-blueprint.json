{
  "entities": {
    "WaitlistSubscriber": {
      "title": "Waitlist Subscriber",
      "description": "A person who joined the morning app waitlist",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when waitlist email was submitted"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "synced"],
          "description": "Status of Google Sheet sync"
        },
        "syncedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when synced to Google Sheet"
        },
        "emailStatus": {
          "type": "string",
          "enum": ["none", "sent", "failed"],
          "description": "Status of auto-reply welcome email send"
        },
        "emailError": {
          "type": "string",
          "description": "Detailed error message if the welcome email failed to send"
        },
        "feedback": {
          "type": "string",
          "description": "Optional product feedback or requests submitted by the user"
        }
      },
      "required": ["email", "createdAt", "status"]
    },
    "SheetsConfig": {
      "title": "Google Sheets System Config",
      "description": "Stores user config mapping for Sheets integration",
      "type": "object",
      "properties": {
        "spreadsheetId": {
          "type": "string",
          "description": "ID of Google Sheet where waitlist is synchronized"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date when setting was adjusted"
        }
      },
      "required": ["spreadsheetId"]
    },
    "EmailConfig": {
      "title": "Email Auto-Reply Config",
      "description": "Configuration settings for automatic welcome emails when a user signs up to the waitlist",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether welcome auto-reply email is enabled"
        },
        "serviceId": {
          "type": "string",
          "description": "EmailJS Service ID"
        },
        "templateId": {
          "type": "string",
          "description": "EmailJS Template ID"
        },
        "publicKey": {
          "type": "string",
          "description": "EmailJS API/Public Key"
        },
        "senderName": {
          "type": "string",
          "description": "Name of the sender showing up in the email header"
        },
        "replyTo": {
          "type": "string",
          "description": "Reply-to address for subscribers"
        },
        "emailSubject": {
          "type": "string",
          "description": "Subject of the email greeting"
        },
        "emailBody": {
          "type": "string",
          "description": "Body description of the welcome email"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date when setting was adjusted"
        }
      },
      "required": ["enabled"]
    },
    "DeletionRequest": {
      "title": "Data Deletion Request",
      "description": "User request for data erasure",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Registered email address to delete"
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of deletion request"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processed"],
          "description": "Status of deletion request"
        }
      },
      "required": ["email", "requestedAt", "status"]
    },
    "SupportRequest": {
      "title": "Support Request",
      "description": "Support or FAQ request from user",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "category": {
          "type": "string",
          "description": "Category of inquiry"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when support request was created"
        },
        "status": {
          "type": "string",
          "enum": ["new", "resolved"],
          "description": "Inquiry status"
        }
      },
      "required": ["email", "category", "message", "createdAt", "status"]
    }
  },
  "firestore": {
    "/waitlist/{subscriberId}": {
      "schema": "WaitlistSubscriber",
      "description": "Registered morning block waitlist emails"
    },
    "/config/sheets": {
      "schema": "SheetsConfig",
      "description": "Google Sheet spreadsheet configuration"
    },
    "/config/email": {
      "schema": "EmailConfig",
      "description": "Email credentials and customizable auto-reply parameters"
    },
    "/deletion_requests/{requestId}": {
      "schema": "DeletionRequest",
      "description": "GDPR/App Store user data deletion requests"
    },
    "/support_requests/{requestId}": {
      "schema": "SupportRequest",
      "description": "User helpdesk / support tickets"
    }
  }
}
