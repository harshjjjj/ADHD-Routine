rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to submit an email to the waitlist
    match /waitlist/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Config document for sheets is read/write by authenticated user ONLY
    match /config/sheets {
      allow read, write: if request.auth != null;
    }

    // Config document for email is readable by public (to trigger client-side welcome mailers) but writeable by admins ONLY
    match /config/email {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
